{"component": "bug_worker", "bug_id": "3851fff2", "error": "[Errno 36] File name too long: '/home/agentx/self-evolving/src/\\\\s*(.*?)\\\\s*===\\\\n(.*?)\\\\n===END_FILE===\\', re.DOTALL)\\n    matches = pattern.findall(output)\\n    \\n    for file_path, content in matches:\\n        content = content.strip()\\n        # Clean up potential markdown code blocks\\n        if content.startswith(\\'```python\\'):\\n            content = content[9:].strip()\\n        elif content.startswith(\\'```\\'):\\n            content = content[3:].strip()\\n            \\n        if content.endswith(\\'```\\'):\\n            content = content[:-3].strip()\\n            \\n        fixes.append({\\n            \\'file_path\\': file_path.strip(),\\n            \\'content\\': content\\n        })\\n        \\n    if not fixes and \\'===FILE:\\' in output:\\n        logger.warning(\"Detected \\'===FILE:\\' marker but failed to parse correctly. Output might be malformed.\")\\n        \\n    return fixes\\n\\ndef run_review_pipeline(pr_details: Dict[str, Any], llm_client: Any, max_retries: int = 3) -> Dict[str, Any]:\\n    \"\"\"\\n    Runs the PR review pipeline with retries for parsing failures.\\n    \\n    Args:\\n        pr_details (Dict[str, Any]): Pull request details.\\n        llm_client (Any): An object with a `generate(prompt: str) -> str` method.\\n        max_retries (int): Maximum number of retries for parsing failures.\\n        \\n    Returns:\\n        Dict[str, Any]: The review results including status, comments, and parsed fixes.\\n    \"\"\"\\n    if not llm_client:\\n        logger.error(\"LLM client not provided.\")\\n        return {\"status\": \"failed\", \"reason\": \"LLM client missing\"}\\n\\n    prompt = generate_review_prompt(pr_details)\\n    \\n    for attempt in range(max_retries):\\n        try:\\n            llm_response = llm_client.generate(prompt)\\n            fixes = parse_llm_output(llm_response)\\n            \\n            # If we expected fixes but parsing failed, retry\\n            if \\'===FILE:\\' in llm_response and not fixes:\\n                logger.warning(f\"Attempt {attempt + 1}: Failed to parse LLM output. Retrying...\")\\n                prompt += \"\\\\n\\\\nREMINDER: You MUST use the exact ===FILE: path'", "event": "bug_fix_failed", "logger": "evolution.bug_worker", "level": "warning", "correlation_id": "b58f8eab", "timestamp": "2026-05-27T18:55:13.680383Z"}
